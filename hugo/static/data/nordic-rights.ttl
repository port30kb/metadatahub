# ═══════════════════════════════════════════════════════════════
# Nordic Rights and Licenses Vocabulary — Linked Data for metadatahub.eu
# 55 entries: Creative Commons licenses, RightsStatements.org,
# Nordic copyright law concepts, Europeana rights framework,
# and common museum scenario guidance.
#
# Sources:
#   https://creativecommons.org/licenses/
#   https://rightsstatements.org/
#   https://pro.europeana.eu/page/available-rights-statements
#
# Total entries: 55
# ═══════════════════════════════════════════════════════════════

@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix cc:      <http://creativecommons.org/ns#> .
@prefix odrl:    <http://www.w3.org/ns/odrl/2/> .
@prefix mhub:    <https://metadatahub.eu/data/nordic-rights/ontology/> .
@prefix nr:      <https://metadatahub.eu/data/nordic-rights/> .

<https://metadatahub.eu/data/nordic-rights> a skos:ConceptScheme ;
    dcterms:title "Nordic Rights and Licenses Vocabulary"@en ;
    dcterms:title "Nordiskt rattighets- och licensvokabular"@sv ;
    dcterms:description "55 entries covering rights statements, licenses, and copyright concepts for Nordic cultural heritage institutions."@en ;
    dcterms:source <https://creativecommons.org/licenses/> ;
    dcterms:source <https://rightsstatements.org/> ;
    dcterms:source <https://pro.europeana.eu/page/available-rights-statements> ;
    dcterms:creator "Port 30 KB" ;
    dcterms:license <https://creativecommons.org/licenses/by-sa/4.0/> ;
    dcterms:modified "2025-01-15"^^xsd:date .

# Custom property for Europeana tier classification
mhub:europeanaTier a owl:DatatypeProperty ;
    rdfs:label "Europeana licensing tier"@en ;
    rdfs:comment "Classifies a rights statement by Europeana openness tier (tier-1 most restrictive to tier-4 most open)."@en ;
    rdfs:domain skos:Concept ;
    rdfs:range xsd:string .

# ── 1/55: Creative Commons ──
nr:creative-commons a mhub:License, skos:Concept ;
    rdfs:label "Creative Commons"@en ;
    rdfs:label "Creative Commons"@da ;
    rdfs:label "Creative Commons"@fi ;
    rdfs:label "Creative Commons"@nb ;
    rdfs:label "Creative Commons"@sv ;
    skos:prefLabel "Creative Commons"@en ;
    skos:inScheme <https://metadatahub.eu/data/nordic-rights> ;
    skos:definition "Top-level grouping for all Creative Commons license types. Creative Commons provides free, easy-to-use copyright licenses to make a simple and standardized way to give the public permission to share and use creative work."@en ;
    mhub:category "creative-commons" ;
    skos:exactMatch <https://creativecommons.org/> ;
    dcterms:source <https://creativecommons.org/licenses/> .

# ── 2/55: CC0 1.0 Universal (Public Domain Dedication) ──
nr:cc0-1 a mhub:License, skos:Concept ;
    rdfs:label "CC0 1.0 Universal (Public Domain Dedication)"@en ;
    rdfs:label "CC0 1.0 Universel (Frigivelse til det offentlige domæne)"@da ;
    rdfs:label "CC0 1.0 Yleismaailmallinen (Tekijänoikeuksista luopuminen)"@fi ;
    rdfs:label "CC0 1.0 Universell (Fristilling av opphavsrett)"@nb ;
    rdfs:label "CC0 1.0 Universell (Public Domain-dedikation)"@sv ;
    skos:prefLabel "CC0 1.0 Universal (Public Domain Dedication)"@en ;
    skos:prefLabel "CC0 1.0 Universell (Public Domain-dedikation)"@sv ;
    skos:inScheme <https://metadatahub.eu/data/nordic-rights> ;
    skos:definition "Waives all copyright and related rights. The creator dedicates the work to the public domain worldwide. Recommended for metadata, catalog records, and factual data where maximum reuse is desired."@en ;
    mhub:category "creative-commons" ;
    skos:broader nr:creative-commons ;
    skos:exactMatch <https://creativecommons.org/publicdomain/zero/1.0/> ;
    mhub:europeanaTier "tier-4" ;
    skos:scopeNote "Ideal for museum metadata/catalog records, measurement data, and factual descriptions. Cannot be revoked once applied. Note that moral rights (ideell ratt) in Nordic countries cannot be waived."@en ;
    dcterms:source <https://creativecommons.org/licenses/> .

# ── 3/55: Creative Commons Attribution 4.0 International ──
nr:cc-by-4 a mhub:License, skos:Concept ;
    rdfs:label "Creative Commons Attribution 4.0 International"@en ;
    rdfs:label "Creative Commons Navngivelse 4.0 International"@da ;
    rdfs:label "Creative Commons Nimea 4.0 Kansainvalinen"@fi ;
    rdfs:label "Creative Commons Navngivelse 4.0 Internasjonal"@nb ;
    rdfs:label "Creative Commons Erkannande 4.0 Internationell"@sv ;
    skos:prefLabel "Creative Commons Attribution 4.0 International"@en ;
    skos:prefLabel "Creative Commons Erkannande 4.0 Internationell"@sv ;
    skos:inScheme <https://metadatahub.eu/data/nordic-rights> ;
    skos:definition "Allows reuse with attribution. Recommended for museum-created metadata, documentation photos, and digitized works where the museum holds all rights."@en ;
    mhub:category "creative-commons" ;
    skos:broader nr:creative-commons ;
    skos:exactMatch <https://creativecommons.org/licenses/by/4.0/> ;
    mhub:europeanaTier "tier-4" ;
    skos:scopeNote "Use when the museum created the digital reproduction and the original work is in the public domain, or when the museum holds all necessary rights."@en ;
    dcterms:source <https://creativecommons.org/licenses/> .

# ── 4/55: Creative Commons Attribution-ShareAlike 4.0 International ──
nr:cc-by-sa-4 a mhub:License, skos:Concept ;
    rdfs:label "Creative Commons Attribution-ShareAlike 4.0 International"@en ;
    rdfs:label "Creative Commons Navngivelse-DelPaSammeVilkar 4.0 International"@da ;
    rdfs:label "Creative Commons Nimea-JaaSamoin 4.0 Kansainvalinen"@fi ;
    rdfs:label "Creative Commons Navngivelse-DelPaSammeVilkar 4.0 Internasjonal"@nb ;
    rdfs:label "Creative Commons Erkannande-DelaLika 4.0 Internationell"@sv ;
    skos:prefLabel "Creative Commons Attribution-ShareAlike 4.0 International"@en ;
    skos:prefLabel "Creative Commons Erkannande-DelaLika 4.0 Internationell"@sv ;
    skos:inScheme <https://metadatahub.eu/data/nordic-rights> ;
    skos:definition "Allows reuse with attribution, provided derivatives are shared under the same or a compatible license. Ensures that improvements remain openly available."@en ;
    mhub:category "creative-commons" ;
    skos:broader nr:creative-commons ;
    skos:exactMatch <https://creativecommons.org/licenses/by-sa/4.0/> ;
    mhub:europeanaTier "tier-4" ;
    skos:scopeNote "Good for collaborative projects where the museum wants to ensure derivative works also remain open. Wikipedia/Wikimedia Commons uses this license."@en ;
    dcterms:source <https://creativecommons.org/licenses/> .

# ── 5/55: Creative Commons Attribution-NonCommercial 4.0 International ──
nr:cc-by-nc-4 a mhub:License, skos:Concept ;
    rdfs:label "Creative Commons Attribution-NonCommercial 4.0 International"@en ;
    rdfs:label "Creative Commons Navngivelse-IkkeKommerciel 4.0 International"@da ;
    rdfs:label "Creative Commons Nimea-EiKaupallinen 4.0 Kansainvalinen"@fi ;
    rdfs:label "Creative Commons Navngivelse-IkkeKommersiell 4.0 Internasjonal"@nb ;
    rdfs:label "Creative Commons Erkannande-IckeKommersiell 4.0 Internationell"@sv ;
    skos:prefLabel "Creative Commons Attribution-NonCommercial 4.0 International"@en ;
    skos:prefLabel "Creative Commons Erkannande-IckeKommersiell 4.0 Internationell"@sv ;
    skos:inScheme <https://metadatahub.eu/data/nordic-rights> ;
    skos:definition "Allows reuse with attribution for non-commercial purposes only. Commercial use requires separate permission from the rights holder."@en ;
    mhub:category "creative-commons" ;
    skos:broader nr:creative-commons ;
    skos:exactMatch <https://creativecommons.org/licenses/by-nc/4.0/> ;
    mhub:europeanaTier "tier-2" ;
    skos:scopeNote "Use when the museum wants to allow educational and personal reuse but restrict commercial exploitation. Note that 'non-commercial' can be ambiguous in practice."@en ;
    dcterms:source <https://creativecommons.org/licenses/> .

# ── 6/55: Creative Commons Attribution-NonCommercial-ShareAlike 4.0 International ──
nr:cc-by-nc-sa-4 a mhub:License, skos:Concept ;
    rdfs:label "Creative Commons Attribution-NonCommercial-ShareAlike 4.0 International"@en ;
    rdfs:label "Creative Commons Navngivelse-IkkeKommerciel-DelPaSammeVilkar 4.0 International"@da ;
    rdfs:label "Creative Commons Nimea-EiKaupallinen-JaaSamoin 4.0 Kansainvalinen"@fi ;
    rdfs:label "Creative Commons Navngivelse-IkkeKommersiell-DelPaSammeVilkar 4.0 Internasjonal"@nb ;
    rdfs:label "Creative Commons Erkannande-IckeKommersiell-DelaLika 4.0 Internationell"@sv ;
    skos:prefLabel "Creative Commons Attribution-NonCommercial-ShareAlike 4.0 International"@en ;
    skos:prefLabel "Creative Commons Erkannande-IckeKommersiell-DelaLika 4.0 Internationell"@sv ;
    skos:inScheme <https://metadatahub.eu/data/nordic-rights> ;
    skos:definition "Allows non-commercial reuse with attribution, provided derivatives are shared under the same or compatible license."@en ;
    mhub:category "creative-commons" ;
    skos:broader nr:creative-commons ;
    skos:exactMatch <https://creativecommons.org/licenses/by-nc-sa/4.0/> ;
    mhub:europeanaTier "tier-2" ;
    skos:scopeNote "Combines non-commercial restriction with share-alike requirement. Common in educational and cultural heritage contexts."@en ;
    dcterms:source <https://creativecommons.org/licenses/> .

# ── 7/55: Creative Commons Attribution-NoDerivatives 4.0 International ──
nr:cc-by-nd-4 a mhub:License, skos:Concept ;
    rdfs:label "Creative Commons Attribution-NoDerivatives 4.0 International"@en ;
    rdfs:label "Creative Commons Navngivelse-IngenBearbejdelser 4.0 International"@da ;
    rdfs:label "Creative Commons Nimea-EiMuutoksia 4.0 Kansainvalinen"@fi ;
    rdfs:label "Creative Commons Navngivelse-IngenBearbeidelser 4.0 Internasjonal"@nb ;
    rdfs:label "Creative Commons Erkannande-IngaBearbetningar 4.0 Internationell"@sv ;
    skos:prefLabel "Creative Commons Attribution-NoDerivatives 4.0 International"@en ;
    skos:prefLabel "Creative Commons Erkannande-IngaBearbetningar 4.0 Internationell"@sv ;
    skos:inScheme <https://metadatahub.eu/data/nordic-rights> ;
    skos:definition "Allows redistribution with attribution but no derivative works. The work must be shared in its original, unmodified form."@en ;
    mhub:category "creative-commons" ;
    skos:broader nr:creative-commons ;
    skos:exactMatch <https://creativecommons.org/licenses/by-nd/4.0/> ;
    mhub:europeanaTier "tier-3" ;
    skos:scopeNote "Rarely recommended for cultural heritage data. Use when integrity of the original representation is paramount (e.g., exhibition catalog essays)."@en ;
    dcterms:source <https://creativecommons.org/licenses/> .

# ── 8/55: Creative Commons Attribution-NonCommercial-NoDerivatives 4.0 International ──
nr:cc-by-nc-nd-4 a mhub:License, skos:Concept ;
    rdfs:label "Creative Commons Attribution-NonCommercial-NoDerivatives 4.0 International"@en ;
    rdfs:label "Creative Commons Navngivelse-IkkeKommerciel-IngenBearbejdelser 4.0 International"@da ;
    rdfs:label "Creative Commons Nimea-EiKaupallinen-EiMuutoksia 4.0 Kansainvalinen"@fi ;
    rdfs:label "Creative Commons Navngivelse-IkkeKommersiell-IngenBearbeidelser 4.0 Internasjonal"@nb ;
    rdfs:label "Creative Commons Erkannande-IckeKommersiell-IngaBearbetningar 4.0 Internationell"@sv ;
    skos:prefLabel "Creative Commons Attribution-NonCommercial-NoDerivatives 4.0 International"@en ;
    skos:prefLabel "Creative Commons Erkannande-IckeKommersiell-IngaBearbetningar 4.0 Internationell"@sv ;
    skos:inScheme <https://metadatahub.eu/data/nordic-rights> ;
    skos:definition "The most restrictive Creative Commons license. Allows downloading and sharing with attribution, but no commercial use and no modifications."@en ;
    mhub:category "creative-commons" ;
    skos:broader nr:creative-commons ;
    skos:exactMatch <https://creativecommons.org/licenses/by-nc-nd/4.0/> ;
    mhub:europeanaTier "tier-1" ;
    skos:scopeNote "Most restrictive CC license. Consider whether a more open license or a rights statement would be more appropriate."@en ;
    dcterms:source <https://creativecommons.org/licenses/> .

# ── 9/55: Public Domain Mark 1.0 ──
nr:pdm-1 a mhub:License, skos:Concept ;
    rdfs:label "Public Domain Mark 1.0"@en ;
    rdfs:label "Public Domain-markering 1.0"@da ;
    rdfs:label "Public Domain -merkinta 1.0"@fi ;
    rdfs:label "Public Domain-merke 1.0"@nb ;
    rdfs:label "Public Domain-marke 1.0"@sv ;
    skos:prefLabel "Public Domain Mark 1.0"@en ;
    skos:prefLabel "Public Domain-marke 1.0"@sv ;
    skos:inScheme <https://metadatahub.eu/data/nordic-rights> ;
    skos:definition "Indicates that a work is free of known copyright restrictions worldwide. Not a license but a label indicating public domain status."@en ;
    mhub:category "creative-commons" ;
    skos:broader nr:creative-commons ;
    skos:exactMatch <https://creativecommons.org/publicdomain/mark/1.0/> ;
    mhub:europeanaTier "tier-4" ;
    skos:scopeNote "Use for works where copyright has expired (typically 70 years after author's death in the EU/EEA). The work itself must be in the public domain; this mark does not place it there."@en ;
    dcterms:source <https://creativecommons.org/licenses/> .

# ── 10/55: RightsStatements.org ──
nr:rights-statements a mhub:RightsStatement, skos:Concept ;
    rdfs:label "RightsStatements.org"@en ;
    rdfs:label "RightsStatements.org"@da ;
    rdfs:label "RightsStatements.org"@fi ;
    rdfs:label "RightsStatements.org"@nb ;
    rdfs:label "RightsStatements.org"@sv ;
    skos:prefLabel "RightsStatements.org"@en ;
    skos:inScheme <https://metadatahub.eu/data/nordic-rights> ;
    skos:definition "Top-level grouping for RightsStatements.org standardized rights statements. Provides a set of 12 standardized rights statements for use by cultural heritage institutions to communicate the copyright and reuse status of digital objects."@en ;
    mhub:category "rights-statement" ;
    skos:exactMatch <https://rightsstatements.org/> ;
    dcterms:source <https://creativecommons.org/licenses/> .

# ── 11/55: In Copyright ──
nr:inc a mhub:RightsStatement, skos:Concept ;
    rdfs:label "In Copyright"@en ;
    rdfs:label "Ophavsretligt beskyttet"@da ;
    rdfs:label "Tekijanoikeuden alainen"@fi ;
    rdfs:label "Opphavsrettsbeskyttet"@nb ;
    rdfs:label "Upphovsrattsskyddat"@sv ;
    skos:prefLabel "In Copyright"@en ;
    skos:prefLabel "Upphovsrattsskyddat"@sv ;
    skos:inScheme <https://metadatahub.eu/data/nordic-rights> ;
    skos:definition "The item is in copyright. The rights holder has not given authorization for reuse. Users may only use the item in ways permitted by copyright limitations and exceptions."@en ;
    mhub:category "rights-statement" ;
    skos:broader nr:rights-statements ;
    skos:exactMatch <http://rightsstatements.org/vocab/InC/1.0/> ;
    mhub:europeanaTier "tier-1" ;
    skos:scopeNote "Default statement for copyrighted works. Ensure you have verified the copyright status before applying."@en ;
    dcterms:source <https://creativecommons.org/licenses/> .

# ── 12/55: In Copyright - EU Orphan Work ──
nr:inc-ow-eu a mhub:RightsStatement, skos:Concept ;
    rdfs:label "In Copyright - EU Orphan Work"@en ;
    rdfs:label "Ophavsretligt beskyttet - EU foraldrelost vark"@da ;
    rdfs:label "Tekijanoikeuden alainen - EU orpoteos"@fi ;
    rdfs:label "Opphavsrettsbeskyttet - EU foreldrelost verk"@nb ;
    rdfs:label "Upphovsrattsskyddat - EU foraldralost verk"@sv ;
    skos:prefLabel "In Copyright - EU Orphan Work"@en ;
    skos:prefLabel "Upphovsrattsskyddat - EU foraldralost verk"@sv ;
    skos:inScheme <https://metadatahub.eu/data/nordic-rights> ;
    skos:definition "The item has been identified as an orphan work in the EU. A diligent search for the rights holder has been conducted in accordance with Directive 2012/28/EU."@en ;
    mhub:category "rights-statement" ;
    skos:broader nr:rights-statements ;
    skos:exactMatch <http://rightsstatements.org/vocab/InC-OW-EU/1.0/> ;
    mhub:europeanaTier "tier-1" ;
    skos:scopeNote "Requires a documented diligent search conducted according to EU Orphan Works Directive. The search must be recorded in the EUIPO Orphan Works Database."@en ;
    dcterms:source <https://creativecommons.org/licenses/> .

# ── 13/55: In Copyright - Educational Use Permitted ──
nr:inc-edu a mhub:RightsStatement, skos:Concept ;
    rdfs:label "In Copyright - Educational Use Permitted"@en ;
    rdfs:label "Ophavsretligt beskyttet - Undervisningsbrug tilladt"@da ;
    rdfs:label "Tekijanoikeuden alainen - Opetuskaytto sallittu"@fi ;
    rdfs:label "Opphavsrettsbeskyttet - Undervisningsbruk tillatt"@nb ;
    rdfs:label "Upphovsrattsskyddat - Utbildningsanvandning tilllaten"@sv ;
    skos:prefLabel "In Copyright - Educational Use Permitted"@en ;
    skos:prefLabel "Upphovsrattsskyddat - Utbildningsanvandning tilllaten"@sv ;
    skos:inScheme <https://metadatahub.eu/data/nordic-rights> ;
    skos:definition "The item is in copyright, but the rights holder has authorized educational use. Non-educational use requires additional permission."@en ;
    mhub:category "rights-statement" ;
    skos:broader nr:rights-statements ;
    skos:exactMatch <http://rightsstatements.org/vocab/InC-EDU/1.0/> ;
    mhub:europeanaTier "tier-1" ;
    skos:scopeNote "Use when the rights holder has granted specific permission for educational use. Define 'educational use' clearly in the institution's terms."@en ;
    dcterms:source <https://creativecommons.org/licenses/> .

# ── 14/55: In Copyright - Non-Commercial Use Permitted ──
nr:inc-nc a mhub:RightsStatement, skos:Concept ;
    rdfs:label "In Copyright - Non-Commercial Use Permitted"@en ;
    rdfs:label "Ophavsretligt beskyttet - Ikke-kommerciel brug tilladt"@da ;
    rdfs:label "Tekijanoikeuden alainen - Ei-kaupallinen kaytto sallittu"@fi ;
    rdfs:label "Opphavsrettsbeskyttet - Ikke-kommersiell bruk tillatt"@nb ;
    rdfs:label "Upphovsrattsskyddat - Icke-kommersiell anvandning tilllaten"@sv ;
    skos:prefLabel "In Copyright - Non-Commercial Use Permitted"@en ;
    skos:prefLabel "Upphovsrattsskyddat - Icke-kommersiell anvandning tilllaten"@sv ;
    skos:inScheme <https://metadatahub.eu/data/nordic-rights> ;
    skos:definition "The item is in copyright, but the rights holder has authorized non-commercial use. Commercial use requires additional permission."@en ;
    mhub:category "rights-statement" ;
    skos:broader nr:rights-statements ;
    skos:exactMatch <http://rightsstatements.org/vocab/InC-NC/1.0/> ;
    mhub:europeanaTier "tier-2" ;
    skos:scopeNote "Use when the rights holder has explicitly permitted non-commercial reuse. Different from CC-BY-NC in that it does not grant a formal license."@en ;
    dcterms:source <https://creativecommons.org/licenses/> .

# ── 15/55: In Copyright - Rights-holder(s) Unlocatable or Unidentifiable ──
nr:inc-ruu a mhub:RightsStatement, skos:Concept ;
    rdfs:label "In Copyright - Rights-holder(s) Unlocatable or Unidentifiable"@en ;
    rdfs:label "Ophavsretligt beskyttet - Rettighedshaver ikke lokaliserbar eller identificerbar"@da ;
    rdfs:label "Tekijanoikeuden alainen - Oikeudenhaltijaa ei loydeta tai tunnisteta"@fi ;
    rdfs:label "Opphavsrettsbeskyttet - Rettighetshaver ikke lokaliserbar eller identifiserbar"@nb ;
    rdfs:label "Upphovsrattsskyddat - Rattighetsinnehavare ej lokaliserbar eller identifierbar"@sv ;
    skos:prefLabel "In Copyright - Rights-holder(s) Unlocatable or Unidentifiable"@en ;
    skos:prefLabel "Upphovsrattsskyddat - Rattighetsinnehavare ej lokaliserbar eller identifierbar"@sv ;
    skos:inScheme <https://metadatahub.eu/data/nordic-rights> ;
    skos:definition "The item is in copyright but the rights holder has not been identified or located after a reasonable investigation. Not an EU orphan work designation."@en ;
    mhub:category "rights-statement" ;
    skos:broader nr:rights-statements ;
    skos:exactMatch <http://rightsstatements.org/vocab/InC-RUU/1.0/> ;
    mhub:europeanaTier "tier-1" ;
    skos:scopeNote "Use when a search has been conducted but does not meet the EU Orphan Works Directive requirements. Document the search efforts undertaken."@en ;
    dcterms:source <https://creativecommons.org/licenses/> .

# ── 16/55: No Copyright - Contractual Restrictions ──
nr:noc-cr a mhub:RightsStatement, skos:Concept ;
    rdfs:label "No Copyright - Contractual Restrictions"@en ;
    rdfs:label "Ingen ophavsret - Kontraktmaessige begraensninger"@da ;
    rdfs:label "Ei tekijanoikeutta - Sopimusrajoitukset"@fi ;
    rdfs:label "Ingen opphavsrett - Kontraktsmessige begrensninger"@nb ;
    rdfs:label "Ingen upphovsratt - Avtalsmassiga begransningar"@sv ;
    skos:prefLabel "No Copyright - Contractual Restrictions"@en ;
    skos:prefLabel "Ingen upphovsratt - Avtalsmassiga begransningar"@sv ;
    skos:inScheme <https://metadatahub.eu/data/nordic-rights> ;
    skos:definition "The underlying work is not in copyright but contractual restrictions apply to the digital surrogate. Common when a third party digitized the work under contract."@en ;
    mhub:category "rights-statement" ;
    skos:broader nr:rights-statements ;
    skos:exactMatch <http://rightsstatements.org/vocab/NoC-CR/1.0/> ;
    mhub:europeanaTier "tier-3" ;
    skos:scopeNote "Use when a digitization partner's contract restricts reuse of the digital copy. The original work remains in the public domain."@en ;
    dcterms:source <https://creativecommons.org/licenses/> .

# ── 17/55: No Copyright - Other Known Legal Restrictions ──
nr:noc-oklr a mhub:RightsStatement, skos:Concept ;
    rdfs:label "No Copyright - Other Known Legal Restrictions"@en ;
    rdfs:label "Ingen ophavsret - Andre kendte juridiske begraensninger"@da ;
    rdfs:label "Ei tekijanoikeutta - Muut tunnetut oikeudelliset rajoitukset"@fi ;
    rdfs:label "Ingen opphavsrett - Andre kjente rettslige begrensninger"@nb ;
    rdfs:label "Ingen upphovsratt - Andra kanda rattsliga begransningar"@sv ;
    skos:prefLabel "No Copyright - Other Known Legal Restrictions"@en ;
    skos:prefLabel "Ingen upphovsratt - Andra kanda rattsliga begransningar"@sv ;
    skos:inScheme <https://metadatahub.eu/data/nordic-rights> ;
    skos:definition "The work is not in copyright but other legal restrictions prevent free reuse. May include cultural heritage protection laws, privacy laws, or export restrictions."@en ;
    mhub:category "rights-statement" ;
    skos:broader nr:rights-statements ;
    skos:exactMatch <http://rightsstatements.org/vocab/NoC-OKLR/1.0/> ;
    mhub:europeanaTier "tier-3" ;
    skos:scopeNote "Use when non-copyright legal restrictions apply, such as cultural heritage protection legislation or privacy regulations (GDPR)."@en ;
    dcterms:source <https://creativecommons.org/licenses/> .

# ── 18/55: No Copyright - United States ──
nr:noc-us a mhub:RightsStatement, skos:Concept ;
    rdfs:label "No Copyright - United States"@en ;
    rdfs:label "Ingen ophavsret - USA"@da ;
    rdfs:label "Ei tekijanoikeutta - Yhdysvallat"@fi ;
    rdfs:label "Ingen opphavsrett - USA"@nb ;
    rdfs:label "Ingen upphovsratt - Forenta Staterna"@sv ;
    skos:prefLabel "No Copyright - United States"@en ;
