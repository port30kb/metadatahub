    skos:exactMatch <http://rightsstatements.org/vocab/CNE/1.0/> ;
    mhub:europeanaTier "tier-1" ;
    skos:scopeNote "A temporary status. Institutions should work toward evaluating and assigning a more specific rights statement over time."@en ;
    dcterms:source <https://creativecommons.org/licenses/> .

# ── 20/55: Copyright Undetermined ──
