    skos:prefLabel "Europeana Niva 2: Begransad ateranvandning"@sv ;
    skos:inScheme <https://metadatahub.eu/data/nordic-rights> ;
    skos:definition "The restricted reuse tier. Includes CC-BY-NC and CC-BY-NC-SA licenses. Content can be reused for non-commercial purposes with attribution."@en ;
    mhub:category "europeana-framework" ;
    skos:broader nr:europeana-framework ;
    skos:scopeNote "Suitable for content where the institution needs to restrict commercial exploitation. Non-commercial licenses are widely used in education."@en ;
    dcterms:source <https://creativecommons.org/licenses/> .

# ── 41/55: Europeana Tier 3: Free Reuse with Conditions ──
nr:europeana-tier-3 a mhub:RightsFramework, skos:Concept ;
    rdfs:label "Europeana Tier 3: Free Reuse with Conditions"@en ;
    rdfs:label "Europeana Niveau 3: Fri genbrug med vilkar"@da ;
    rdfs:label "Europeana Taso 3: Vapaa uudelleenkaytto ehdoin"@fi ;
    rdfs:label "Europeana Niva 3: Fri gjenbruk med vilkar"@nb ;
    rdfs:label "Europeana Niva 3: Fri ateranvandning med villkor"@sv ;
    skos:prefLabel "Europeana Tier 3: Free Reuse with Conditions"@en ;
    skos:prefLabel "Europeana Niva 3: Fri ateranvandning med villkor"@sv ;
    skos:inScheme <https://metadatahub.eu/data/nordic-rights> ;
    skos:definition "Free reuse tier with conditions. Includes CC-BY-ND and NoC-CR (contractual restrictions). Content is generally reusable but with some limitations."@en ;
    mhub:category "europeana-framework" ;
    skos:broader nr:europeana-framework ;
    skos:scopeNote "A good middle ground. Content reaches a broad audience while maintaining some control over how it is presented or used."@en ;
    dcterms:source <https://creativecommons.org/licenses/> .

# ── 42/55: Europeana Tier 4: Open / Public Domain ──
nr:europeana-tier-4 a mhub:RightsFramework, skos:Concept ;
    rdfs:label "Europeana Tier 4: Open / Public Domain"@en ;
    rdfs:label "Europeana Niveau 4: Aben / Public Domain"@da ;
    rdfs:label "Europeana Taso 4: Avoin / Public Domain"@fi ;
    rdfs:label "Europeana Niva 4: Apen / Public Domain"@nb ;
    rdfs:label "Europeana Niva 4: Oppen / Public Domain"@sv ;
    skos:prefLabel "Europeana Tier 4: Open / Public Domain"@en ;
    skos:prefLabel "Europeana Niva 4: Oppen / Public Domain"@sv ;
    skos:inScheme <https://metadatahub.eu/data/nordic-rights> ;
    skos:definition "The most open tier. Includes CC0, CC-BY, CC-BY-SA, Public Domain Mark, and NoC-US. Content is freely reusable, maximizing cultural and educational impact."@en ;
    mhub:category "europeana-framework" ;
    skos:broader nr:europeana-framework ;
    skos:scopeNote "The gold standard for open cultural heritage. Maximizes discoverability, reuse, and impact. Strongly recommended for metadata and public domain reproductions."@en ;
    dcterms:source <https://creativecommons.org/licenses/> .

# ── 43/55: Europeana Data Exchange Agreement ──
nr:europeana-dea a mhub:RightsFramework, skos:Concept ;
    rdfs:label "Europeana Data Exchange Agreement"@en ;
    rdfs:label "Europeanas dataudvekslingsaftale"@da ;
    rdfs:label "Europeanan tiedonvaihtosopimus"@fi ;
    rdfs:label "Europeanas datautvekslingsavtale"@nb ;
    rdfs:label "Europeanas datautbytesavtal"@sv ;
    skos:prefLabel "Europeana Data Exchange Agreement"@en ;
    skos:prefLabel "Europeanas datautbytesavtal"@sv ;
    skos:inScheme <https://metadatahub.eu/data/nordic-rights> ;
    skos:definition "The agreement governing data exchange between Europeana and its data providers. Requires metadata to be provided under CC0 to enable maximum interoperability and reuse."@en ;
    mhub:category "europeana-framework" ;
    skos:broader nr:europeana-framework ;
    skos:exactMatch <https://pro.europeana.eu/page/the-data-exchange-agreement> ;
    skos:scopeNote "All metadata submitted to Europeana must be licensed under CC0 per this agreement. This applies to descriptive metadata only, not to the digital objects themselves."@en ;
    dcterms:source <https://creativecommons.org/licenses/> .

# ── 44/55: Europeana Usage Guidelines for Metadata ──
nr:europeana-metadata-guidelines a mhub:RightsFramework, skos:Concept ;
    rdfs:label "Europeana Usage Guidelines for Metadata"@en ;
    rdfs:label "Europeanas retningslinjer for brug af metadata"@da ;
    rdfs:label "Europeanan metatiedon kayttoohjeet"@fi ;
    rdfs:label "Europeanas retningslinjer for bruk av metadata"@nb ;
    rdfs:label "Europeanas riktlinjer for anvandning av metadata"@sv ;
    skos:prefLabel "Europeana Usage Guidelines for Metadata"@en ;
    skos:prefLabel "Europeanas riktlinjer for anvandning av metadata"@sv ;
    skos:inScheme <https://metadatahub.eu/data/nordic-rights> ;
    skos:definition "Guidelines specifying how Europeana metadata should be used and attributed. Metadata provided to Europeana is available under CC0 for maximum reuse."@en ;
    mhub:category "europeana-framework" ;
    skos:broader nr:europeana-framework ;
    skos:exactMatch <https://pro.europeana.eu/page/usage-guidelines-for-metadata> ;
    skos:scopeNote "Follow these guidelines when reusing metadata obtained from the Europeana API or portal. Attribution is encouraged as good practice even though CC0 does not legally require it."@en ;
    dcterms:source <https://creativecommons.org/licenses/> .

# ── 45/55: Europeana Public Domain Charter ──
nr:europeana-pd-charter a mhub:RightsFramework, skos:Concept ;
    rdfs:label "Europeana Public Domain Charter"@en ;
    rdfs:label "Europeanas Public Domain-charter"@da ;
    rdfs:label "Europeanan Public Domain -peruskirja"@fi ;
    rdfs:label "Europeanas Public Domain-charter"@nb ;
    rdfs:label "Europeanas Public Domain-stadga"@sv ;
    skos:prefLabel "Europeana Public Domain Charter"@en ;
    skos:prefLabel "Europeanas Public Domain-stadga"@sv ;
    skos:inScheme <https://metadatahub.eu/data/nordic-rights> ;
    skos:definition "Europeana's charter affirming that works in the public domain should remain freely available. Digitization of public domain works should not create new exclusive rights over the digital reproductions."@en ;
    mhub:category "europeana-framework" ;
    skos:broader nr:europeana-framework ;
    skos:exactMatch <https://pro.europeana.eu/page/the-europeana-public-domain-charter> ;
    skos:scopeNote "Key principle: faithful digital reproductions of public domain 2D works should not be restricted by new copyright claims. This reflects the spirit of open access to cultural heritage."@en ;
    dcterms:source <https://creativecommons.org/licenses/> .

# ── 46/55: Common Museum Rights Scenarios ──
nr:museum-scenarios a mhub:UsageScenario, skos:Concept ;
    rdfs:label "Common Museum Rights Scenarios"@en ;
    rdfs:label "Almindelige museumsrettighedsscenarier"@da ;
    rdfs:label "Yleiset museooikeusskenaariot"@fi ;
    rdfs:label "Vanlige museumsrettighetsscenarier"@nb ;
    rdfs:label "Vanliga museirattighetsscenarier"@sv ;
    skos:prefLabel "Common Museum Rights Scenarios"@en ;
    skos:prefLabel "Vanliga museirattighetsscenarier"@sv ;
    skos:inScheme <https://metadatahub.eu/data/nordic-rights> ;
    skos:definition "Top-level grouping for common rights scenarios encountered by Nordic museums when digitizing and publishing collection materials."@en ;
    mhub:category "museum-scenario" ;
    dcterms:source <https://creativecommons.org/licenses/> .

# ── 47/55: Pre-1900 Artwork (Photographer Unknown) ──
nr:scenario-pre-1900-artwork a mhub:UsageScenario, skos:Concept ;
    rdfs:label "Pre-1900 Artwork (Photographer Unknown)"@en ;
    rdfs:label "Kunstvaerk for 1900 (fotograf ukendt)"@da ;
    rdfs:label "Ennen vuotta 1900 luotu taideteos (valokuvaaja tuntematon)"@fi ;
    rdfs:label "Kunstverk for 1900 (fotograf ukjent)"@nb ;
    rdfs:label "Konstverk fore 1900 (fotograf okand)"@sv ;
    skos:prefLabel "Pre-1900 Artwork (Photographer Unknown)"@en ;
    skos:prefLabel "Konstverk fore 1900 (fotograf okand)"@sv ;
    skos:inScheme <https://metadatahub.eu/data/nordic-rights> ;
    skos:definition "Artwork created before 1900 where the photographer of the digital reproduction is unknown. The original is almost certainly in the public domain (70-year post-mortem rule), but the digital reproduction may have limited protection as a photographic image."@en ;
    mhub:category "museum-scenario" ;
    skos:broader nr:museum-scenarios ;
    skos:scopeNote "Recommended: Public Domain Mark 1.0 for the original work. For faithful 2D reproductions, follow the Europeana Public Domain Charter principle. If the photographer is a museum employee, apply the museum's standard open license."@en ;
    dcterms:source <https://creativecommons.org/licenses/> .

# ── 48/55: Contemporary Artwork with Living Artist ──
nr:scenario-contemporary-artwork a mhub:UsageScenario, skos:Concept ;
    rdfs:label "Contemporary Artwork with Living Artist"@en ;
    rdfs:label "Samtidskunstvaerk med levende kunstner"@da ;
    rdfs:label "Nykytaideteos elavan taiteilijan kanssa"@fi ;
    rdfs:label "Samtidskunstverk med levende kunstner"@nb ;
    rdfs:label "Samtida konstverk med levande konstnar"@sv ;
    skos:prefLabel "Contemporary Artwork with Living Artist"@en ;
    skos:prefLabel "Samtida konstverk med levande konstnar"@sv ;
    skos:inScheme <https://metadatahub.eu/data/nordic-rights> ;
    skos:definition "Artworks by living or recently deceased artists where copyright is still active. Both the original work and the documentation photograph may be separately protected."@en ;
    mhub:category "museum-scenario" ;
    skos:broader nr:museum-scenarios ;
    skos:scopeNote "Recommended: InC (In Copyright) unless the artist has granted a specific license. Consider extended collective licensing (avtalslicens) for online access. Contact Bildupphovsratt (SE), Kuvasto (FI), or BONO (NO)."@en ;
    dcterms:source <https://creativecommons.org/licenses/> .

# ── 49/55: Museum-Commissioned Photography of 2D Works ──
nr:scenario-museum-photography-2d a mhub:UsageScenario, skos:Concept ;
    rdfs:label "Museum-Commissioned Photography of 2D Works"@en ;
    rdfs:label "Museumsbestilte fotografier af 2D-vaerker"@da ;
    rdfs:label "Museon tilaamat valokuvat 2D-teoksista"@fi ;
    rdfs:label "Museumsbestilte fotografier av 2D-verk"@nb ;
    rdfs:label "Museibestallda fotografier av 2D-verk"@sv ;
    skos:prefLabel "Museum-Commissioned Photography of 2D Works"@en ;
    skos:prefLabel "Museibestallda fotografier av 2D-verk"@sv ;
    skos:inScheme <https://metadatahub.eu/data/nordic-rights> ;
    skos:definition "Photographs commissioned by the museum to document flat/2D collection objects. For faithful reproductions of public domain 2D works, the photograph may not generate independent copyright (following the Europeana Public Domain Charter)."@en ;
    mhub:category "museum-scenario" ;
    skos:broader nr:museum-scenarios ;
    skos:scopeNote "If the original 2D work is in the public domain, recommended: Public Domain Mark or CC0 for faithful reproductions. If the original is in copyright, the photograph adds a layer of rights requiring both artist and photographer clearance."@en ;
    dcterms:source <https://creativecommons.org/licenses/> .

# ── 50/55: Archaeological Finds (State Ownership) ──
nr:scenario-archaeological-finds a mhub:UsageScenario, skos:Concept ;
    rdfs:label "Archaeological Finds (State Ownership)"@en ;
    rdfs:label "Arkaeologiske fund (statseje)"@da ;
    rdfs:label "Arkeologiset loydot (valtion omistus)"@fi ;
    rdfs:label "Arkeologiske funn (statlig eiendom)"@nb ;
    rdfs:label "Arkeologiska fynd (statlig aganderatt)"@sv ;
    skos:prefLabel "Archaeological Finds (State Ownership)"@en ;
    skos:prefLabel "Arkeologiska fynd (statlig aganderatt)"@sv ;
    skos:inScheme <https://metadatahub.eu/data/nordic-rights> ;
    skos:definition "Archaeological objects typically owned by the state under Nordic cultural heritage legislation. Copyright may not apply to the objects themselves, but documentation photographs may be protected."@en ;
    mhub:category "museum-scenario" ;
    skos:broader nr:museum-scenarios ;
    skos:scopeNote "The objects themselves are generally not copyrighted (utilitarian or ancient). Recommended: CC-BY 4.0 or CC0 for museum-created documentation photographs. Respect any export or cultural property restrictions (NoC-OKLR)."@en ;
    dcterms:source <https://creativecommons.org/licenses/> .

# ── 51/55: Born-Digital Museum Content ──
nr:scenario-born-digital a mhub:UsageScenario, skos:Concept ;
    rdfs:label "Born-Digital Museum Content"@en ;
    rdfs:label "Digitalt fodt museumsindhold"@da ;
    rdfs:label "Digitaalisesti syntynyt museosisalto"@fi ;
    rdfs:label "Digitalt fodt museumsinnhold"@nb ;
    rdfs:label "Digitalt fodd museiinnehall"@sv ;
    skos:prefLabel "Born-Digital Museum Content"@en ;
    skos:prefLabel "Digitalt fodd museiinnehall"@sv ;
    skos:inScheme <https://metadatahub.eu/data/nordic-rights> ;
    skos:definition "Content created directly in digital form by the museum, such as virtual exhibitions, 3D scans, interactive guides, educational materials, and social media content."@en ;
    mhub:category "museum-scenario" ;
    skos:broader nr:museum-scenarios ;
    skos:scopeNote "The museum typically holds all rights. Recommended: CC-BY 4.0 for maximum reuse, or CC-BY-SA 4.0 if share-alike is desired. Use CC0 for metadata and factual data."@en ;
    dcterms:source <https://creativecommons.org/licenses/> .

# ── 52/55: Metadata and Catalog Records ──
nr:scenario-metadata-records a mhub:UsageScenario, skos:Concept ;
    rdfs:label "Metadata and Catalog Records"@en ;
    rdfs:label "Metadata og katalogposter"@da ;
    rdfs:label "Metatiedot ja luettelointitietueet"@fi ;
    rdfs:label "Metadata og katalogposter"@nb ;
    rdfs:label "Metadata och katalogposter"@sv ;
    skos:prefLabel "Metadata and Catalog Records"@en ;
    skos:prefLabel "Metadata och katalogposter"@sv ;
    skos:inScheme <https://metadatahub.eu/data/nordic-rights> ;
    skos:definition "Descriptive metadata, catalog records, and structured data about collection objects. Generally factual in nature with limited or no copyright protection, but may be protected as databases."@en ;
    mhub:category "museum-scenario" ;
    skos:broader nr:museum-scenarios ;
    skos:scopeNote "Strongly recommended: CC0. Required by Europeana Data Exchange Agreement. Factual metadata has minimal copyright protection in most cases, making CC0 the natural choice."@en ;
    dcterms:source <https://creativecommons.org/licenses/> .

# ── 53/55: Educational Use of Copyrighted Material ──
nr:scenario-educational-use a mhub:UsageScenario, skos:Concept ;
    rdfs:label "Educational Use of Copyrighted Material"@en ;
    rdfs:label "Undervisningsbrug af ophavsretligt beskyttet materiale"@da ;
    rdfs:label "Tekijanoikeudella suojatun materiaalin opetuskaytto"@fi ;
    rdfs:label "Undervisningsbruk av opphavsrettsbeskyttet materiale"@nb ;
    rdfs:label "Utbildningsanvandning av upphovsrattsskyddat material"@sv ;
    skos:prefLabel "Educational Use of Copyrighted Material"@en ;
    skos:prefLabel "Utbildningsanvandning av upphovsrattsskyddat material"@sv ;
    skos:inScheme <https://metadatahub.eu/data/nordic-rights> ;
    skos:definition "Use of copyrighted collection materials for educational purposes such as lectures, teaching materials, and school programs. Nordic copyright laws provide specific exceptions for educational use."@en ;
    mhub:category "museum-scenario" ;
    skos:broader nr:museum-scenarios ;
    skos:scopeNote "Apply InC-EDU if the rights holder has authorized educational use. Otherwise, rely on national copyright exceptions for education (e.g., Swedish Copyright Act Section 42c). Extended collective licensing may also apply."@en ;
    dcterms:source <https://creativecommons.org/licenses/> .

# ── 54/55: Sami Cultural Heritage Considerations ──
nr:scenario-sami-heritage a mhub:UsageScenario, skos:Concept ;
    rdfs:label "Sami Cultural Heritage Considerations"@en ;
    rdfs:label "Samisk kulturarvshensyn"@da ;
    rdfs:label "Saamelaisen kulttuuriperinnon huomiointi"@fi ;
    rdfs:label "Samisk kulturarvshensyn"@nb ;
    rdfs:label "Sami kulturarbi"@se ;
    rdfs:label "Samisk kulturarvshantering"@sv ;
    skos:prefLabel "Sami Cultural Heritage Considerations"@en ;
    skos:prefLabel "Samisk kulturarvshantering"@sv ;
    skos:inScheme <https://metadatahub.eu/data/nordic-rights> ;
    skos:definition "Special considerations for Sami cultural heritage materials, including traditional knowledge, joik recordings, duodji (crafts), and sacred or sensitive cultural objects. Requires engagement with Sami communities and institutions."@en ;
    mhub:category "museum-scenario" ;
    skos:broader nr:museum-scenarios ;
    skos:scopeNote "Standard copyright licenses may be insufficient. Consider Traditional Knowledge labels (Local Contexts). Consult with Sami Parliament (Sametinget) and relevant Sami museums (Ajtte, Siida, RiddoDuottarMuseat). Follow CARE principles for Indigenous data governance."@en ;
    dcterms:source <https://creativecommons.org/licenses/> .

# ── 55/55: Traditional Knowledge Labels ──
nr:scenario-traditional-knowledge a mhub:UsageScenario, skos:Concept ;
    rdfs:label "Traditional Knowledge Labels"@en ;
    rdfs:label "Traditionel vidensmaerkning"@da ;
    rdfs:label "Perinteisen tiedon merkinta"@fi ;
    rdfs:label "Tradisjonell kunnskapsmerking"@nb ;
    rdfs:label "Traditionell kunskapsmarkning"@sv ;
    skos:prefLabel "Traditional Knowledge Labels"@en ;
    skos:prefLabel "Traditionell kunskapsmarkning"@sv ;
    skos:inScheme <https://metadatahub.eu/data/nordic-rights> ;
    skos:definition "Labels developed by the Local Contexts initiative to address intellectual property issues for Indigenous communities. Provide culturally specific information about how traditional knowledge should be accessed and used."@en ;
    mhub:category "museum-scenario" ;
    skos:broader nr:museum-scenarios ;
    skos:exactMatch <https://localcontexts.org/labels/traditional-knowledge-labels/> ;
    skos:scopeNote "TK Labels complement rather than replace standard licenses. They communicate community expectations for use. Applicable to Sami collections and other Indigenous materials in Nordic museums. Work with communities to select appropriate labels."@en ;
    dcterms:source <https://creativecommons.org/licenses/> .
