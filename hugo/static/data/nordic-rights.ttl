    skos:exactMatch <http://rightsstatements.org/vocab/UND/1.0/> ;
    mhub:europeanaTier "tier-1" ;
    skos:scopeNote "Use when an evaluation has been attempted but the status remains unclear. Document what information is missing or uncertain."@en ;
    dcterms:source <https://creativecommons.org/licenses/> .

# ── 21/55: No Known Copyright ──
