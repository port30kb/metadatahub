# ── 28/55: 70-Year Post-Mortem Rule ──
nr:post-mortem-70 a mhub:CopyrightConcept, skos:Concept ;
    rdfs:label "70-Year Post-Mortem Rule"@en ;
    rdfs:label "70 ar efter ophavsmandens dod"@da ;
    rdfs:label "70 vuotta tekijan kuoleman jalkeen"@fi ;
    rdfs:label "70 ar etter opphavsmannens dod"@nb ;
    rdfs:label "70 ar efter upphovsmannens dod"@sv ;
    skos:prefLabel "70-Year Post-Mortem Rule"@en ;
    skos:prefLabel "70 ar efter upphovsmannens dod"@sv ;
    skos:inScheme <https://metadatahub.eu/data/nordic-rights> ;
    skos:definition "Copyright in the EU/EEA expires 70 years after the death of the author (post mortem auctoris). This term was harmonized by EU Directive 2006/116/EC across all member states."@en ;
    mhub:category "nordic-copyright-law" ;
    skos:broader nr:nordic-copyright ;
    skos:scopeNote "For works by known authors, copyright expires on January 1st of the year following the 70th anniversary of the author's death. For anonymous/pseudonymous works, 70 years from publication."@en ;
    dcterms:source <https://creativecommons.org/licenses/> .

# ── 29/55: Freedom of Panorama ──
nr:freedom-of-panorama a mhub:CopyrightConcept, skos:Concept ;
    rdfs:label "Freedom of Panorama"@en ;
    rdfs:label "Panoramafrihed"@da ;
    rdfs:label "Panoraamavapaus"@fi ;
    rdfs:label "Panoramafrihet"@nb ;
    rdfs:label "Panoramafrihet"@sv ;
    skos:prefLabel "Freedom of Panorama"@en ;
    skos:prefLabel "Panoramafrihet"@sv ;
    skos:inScheme <https://metadatahub.eu/data/nordic-rights> ;
    skos:definition "Legal provision allowing photography and reproduction of works permanently situated in public places. Implementation varies significantly across the Nordic countries."@en ;
    mhub:category "nordic-copyright-law" ;
    skos:broader nr:nordic-copyright ;
    skos:scopeNote "Sweden (Section 24): allows reproduction of outdoor public artworks. Denmark (Section 24): similar provision. Finland (Section 25a): limited to buildings and outdoor sculptures. Norway (Section 31): allows reproduction of outdoor works. Always verify current national legislation."@en ;
    dcterms:source <https://creativecommons.org/licenses/> .

# ── 30/55: Public Domain ──
nr:public-domain-concept a mhub:CopyrightConcept, skos:Concept ;
    rdfs:label "Public Domain"@en ;
    rdfs:label "Det fri vark (public domain)"@da ;
    rdfs:label "Public domain (tekijanoikeudesta vapaa)"@fi ;
    rdfs:label "Det fri verket (public domain)"@nb ;
    rdfs:label "Allmanningen (fri fran upphovsratt)"@sv ;
    skos:prefLabel "Public Domain"@en ;
    skos:prefLabel "Allmanningen (fri fran upphovsratt)"@sv ;
    skos:inScheme <https://metadatahub.eu/data/nordic-rights> ;
    skos:definition "Works not protected by copyright, either because protection has expired, been waived, or never existed. In the Nordic context, note that moral rights persist even after economic rights expire."@en ;
    mhub:category "nordic-copyright-law" ;
    skos:broader nr:nordic-copyright ;
    skos:scopeNote "Mark with Public Domain Mark 1.0 or CC0. Remember that moral rights (attribution and integrity) may still apply under Nordic law even for public domain works."@en ;
    dcterms:source <https://creativecommons.org/licenses/> .

# ── 31/55: Orphan Works ──
nr:orphan-works a mhub:CopyrightConcept, skos:Concept ;
    rdfs:label "Orphan Works"@en ;
    rdfs:label "Foraldrelose vaerker"@da ;
    rdfs:label "Orpoteokset"@fi ;
    rdfs:label "Foreldrelose verk"@nb ;
    rdfs:label "Herrelosa verk"@sv ;
    skos:prefLabel "Orphan Works"@en ;
    skos:prefLabel "Herrelosa verk"@sv ;
    skos:inScheme <https://metadatahub.eu/data/nordic-rights> ;
    skos:definition "Works still in copyright whose rights holder cannot be identified or located after a diligent search. EU Directive 2012/28/EU provides a framework for use by cultural heritage institutions."@en ;
    mhub:category "nordic-copyright-law" ;
    skos:broader nr:nordic-copyright ;
    skos:scopeNote "Nordic museums can use orphan works under the EU Directive after conducting and documenting a diligent search. Extended collective licensing (avtalslicens) offers an alternative Nordic approach."@en ;
    dcterms:source <https://creativecommons.org/licenses/> .

# ── 32/55: Extended Collective Licensing ──
nr:extended-collective-licensing a mhub:CopyrightConcept, skos:Concept ;
    rdfs:label "Extended Collective Licensing"@en ;
    rdfs:label "Aftalelicens"@da ;
    rdfs:label "Sopimuslisenssit"@fi ;
    rdfs:label "Avtalelisens"@nb ;
    rdfs:label "Avtalslicens"@sv ;
    skos:prefLabel "Extended Collective Licensing"@en ;
    skos:prefLabel "Avtalslicens"@sv ;
    skos:inScheme <https://metadatahub.eu/data/nordic-rights> ;
    skos:definition "A distinctly Nordic mechanism where agreements between users and representative collecting societies are extended to cover non-member rights holders. Enables mass digitization and online access."@en ;
    mhub:category "nordic-copyright-law" ;
    skos:broader nr:nordic-copyright ;
    skos:scopeNote "Particularly valuable for mass digitization projects. In Sweden, governed by Section 42a-42j of the Copyright Act. Collecting societies include Bildupphovsratt (images) and Bonus Copyright Access (text)."@en ;
    dcterms:source <https://creativecommons.org/licenses/> .

# ── 33/55: Right of Reproduction ──
nr:reproduction-right a mhub:CopyrightConcept, skos:Concept ;
    rdfs:label "Right of Reproduction"@en ;
    rdfs:label "Reproduktionsret"@da ;
    rdfs:label "Kappaleenoikeus"@fi ;
    rdfs:label "Eksemplarfremstillingsrett"@nb ;
    rdfs:label "Mangfaldiganderatt"@sv ;
    skos:prefLabel "Right of Reproduction"@en ;
    skos:prefLabel "Mangfaldiganderatt"@sv ;
    skos:inScheme <https://metadatahub.eu/data/nordic-rights> ;
    skos:definition "The exclusive right of the copyright holder to reproduce the work in any material form, including digital copies. A core economic right under all Nordic copyright acts."@en ;
    mhub:category "nordic-copyright-law" ;
    skos:broader nr:nordic-copyright ;
    skos:scopeNote "Digitization of museum objects constitutes reproduction. Ensure you have authorization from rights holders or rely on applicable exceptions before digitizing."@en ;
    dcterms:source <https://creativecommons.org/licenses/> .

# ── 34/55: Moral Rights ──
nr:moral-rights a mhub:CopyrightConcept, skos:Concept ;
    rdfs:label "Moral Rights"@en ;
    rdfs:label "Ideelle rettigheder"@da ;
    rdfs:label "Moraaliset oikeudet"@fi ;
    rdfs:label "Ideelle rettigheter"@nb ;
    rdfs:label "Ideell ratt"@sv ;
    skos:prefLabel "Moral Rights"@en ;
    skos:prefLabel "Ideell ratt"@sv ;
    skos:inScheme <https://metadatahub.eu/data/nordic-rights> ;
    skos:definition "Non-transferable personal rights of the author including the right of attribution (namnangivelseratt) and the right of integrity (respektratt). In Nordic countries, moral rights cannot be fully waived."@en ;
    mhub:category "nordic-copyright-law" ;
    skos:broader nr:nordic-copyright ;
    skos:scopeNote "Always attribute the creator even when using CC0 or Public Domain Mark. Avoid modifications that could harm the author's reputation, even for public domain works."@en ;
    dcterms:source <https://creativecommons.org/licenses/> .

# ── 35/55: Database Rights (Sui Generis) ──
nr:database-rights a mhub:CopyrightConcept, skos:Concept ;
    rdfs:label "Database Rights (Sui Generis)"@en ;
    rdfs:label "Databaserettigheder (sui generis)"@da ;
    rdfs:label "Tietokantaoikeus (sui generis)"@fi ;
    rdfs:label "Databaserettigheter (sui generis)"@nb ;
    rdfs:label "Databasratt (sui generis)"@sv ;
    skos:prefLabel "Database Rights (Sui Generis)"@en ;
    skos:prefLabel "Databasratt (sui generis)"@sv ;
    skos:inScheme <https://metadatahub.eu/data/nordic-rights> ;
    skos:definition "Sui generis protection for databases under EU Directive 96/9/EC, implemented in all Nordic countries. Protects substantial investment in obtaining, verifying, or presenting database contents for 15 years."@en ;
    mhub:category "nordic-copyright-law" ;
    skos:broader nr:nordic-copyright ;
    skos:scopeNote "Museum collection databases may qualify for sui generis protection. This is separate from copyright in individual entries. Consider CC0 for maximum interoperability of metadata."@en ;
    dcterms:source <https://creativecommons.org/licenses/> .

# ── 36/55: Photographic Works vs. Photographic Images ──
nr:photographic-works-vs-images a mhub:CopyrightConcept, skos:Concept ;
    rdfs:label "Photographic Works vs. Photographic Images"@en ;
    rdfs:label "Fotografiske vaerker vs. fotografiske billeder"@da ;
    rdfs:label "Valokuvateokset vs. valokuvat"@fi ;
    rdfs:label "Fotografiske verk vs. fotografiske bilder"@nb ;
    rdfs:label "Fotografiska verk vs. fotografiska bilder"@sv ;
    skos:prefLabel "Photographic Works vs. Photographic Images"@en ;
    skos:prefLabel "Fotografiska verk vs. fotografiska bilder"@sv ;
    skos:inScheme <https://metadatahub.eu/data/nordic-rights> ;
    skos:definition "Nordic copyright law distinguishes between photographic works (original creative expression, full copyright term) and photographic images (any photograph, shorter protection of 50 years from creation). Critical for museum documentation photography."@en ;
    mhub:category "nordic-copyright-law" ;
    skos:broader nr:nordic-copyright ;
    skos:scopeNote "Most museum documentation photography (catalog photos, condition reports) qualifies as photographic images with 50-year protection. Artistic photography gets full copyright term (70 years post mortem)."@en ;
    dcterms:source <https://creativecommons.org/licenses/> .

# ── 37/55: Museum Reproduction Rights ──
nr:museum-reproduction-rights a mhub:CopyrightConcept, skos:Concept ;
    rdfs:label "Museum Reproduction Rights"@en ;
    rdfs:label "Museets reproduktionsrettigheder"@da ;
    rdfs:label "Museon toisinto-oikeudet"@fi ;
    rdfs:label "Museets reproduksjonsrettigheter"@nb ;
    rdfs:label "Museets reproduktionsratt"@sv ;
    skos:prefLabel "Museum Reproduction Rights"@en ;
    skos:prefLabel "Museets reproduktionsratt"@sv ;
    skos:inScheme <https://metadatahub.eu/data/nordic-rights> ;
    skos:definition "The legal framework governing museum rights to reproduce and make available works in their collections. Varies based on whether the original work is in copyright and whether the reproduction itself generates new rights."@en ;
    mhub:category "nordic-copyright-law" ;
    skos:broader nr:nordic-copyright ;
    skos:scopeNote "For public domain originals, the museum's reproduction may still be protected as a photographic image. The Bridgeman Art Library v. Corel Corp. precedent (US) is not binding in Nordic jurisdictions."@en ;
    dcterms:source <https://creativecommons.org/licenses/> .

