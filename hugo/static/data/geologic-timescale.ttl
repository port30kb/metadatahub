# ── 527/852: Prehistoric Africa (Förhistoriska Afrika) (CulturalAge) ──
ts:africa-prehistoric a gts:GeochronologicAge ;
    rdfs:label "Prehistoric Africa (Förhistoriska Afrika)"@en ;
    skos:inScheme <https://metadatahub.eu/data/geologic-timescale> ;
    skos:definition "Birthplace of Homo sapiens; earliest stone tools (Lomekwian ~3.3 Ma); earliest modern human behavior; rock art; Neolithic revolution in Sahara and Nile; transition to complex societies."@en ;
    gts:rank "CulturalAge" ;
    skos:broader ts:holocene ;
    time:hasBeginning [ rdfs:label "3300000 BCE" ] ;
    time:hasEnd [ rdfs:label "3100 BCE" ] ;
    dcterms:source <https://en.wikipedia.org/wiki/Geologic_time_scale> .

