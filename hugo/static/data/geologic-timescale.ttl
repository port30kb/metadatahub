# ── 32/250: Cambrian Series 2 (Epoch) ──
ts:epoch2-cambrian a gts:GeochronologicEpoch ;
    rdfs:label "Cambrian Series 2"@en ;
    skos:inScheme <https://metadatahub.eu/data/geologic-timescale> ;
    skos:definition "Trilobites diversify; archaeocyathid reefs."@en ;
