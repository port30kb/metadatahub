    dcterms:source <https://en.wikipedia.org/wiki/Geologic_time_scale> .

# ── 29/514: Terreneuvian (Epoch) ──
ts:terreneuvian a gts:GeochronologicEpoch ;
    rdfs:label "Terreneuvian"@en ;
    skos:inScheme <https://metadatahub.eu/data/geologic-timescale> ;
    skos:definition "Earliest Cambrian epoch; small shelly fossils appear."@en ;
    gts:rank "Epoch" ;
    skos:broader ts:cambrian ;
