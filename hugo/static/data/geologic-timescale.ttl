ts:baltic-crusades a gts:GeochronologicAge ;
    rdfs:label "Baltic Crusades Period"@en ;
    skos:inScheme <https://metadatahub.eu/data/geologic-timescale> ;
    skos:definition "Northern Crusades; Christianization of Baltic region; Teutonic Order; Swedish crusades to Finland."@en ;
    gts:rank "CulturalAge" ;
    skos:broader ts:medieval-period ;
    time:hasBeginning [ rdfs:label "1147 CE" ] ;
    time:hasEnd [ rdfs:label "1290 CE" ] ;
    dcterms:source <https://en.wikipedia.org/wiki/Geologic_time_scale> .

# ── 247/250: Hanseatic Period in Scandinavia (CulturalAge) ──
ts:hanseatic-period a gts:GeochronologicAge ;
    rdfs:label "Hanseatic Period in Scandinavia"@en ;
    skos:inScheme <https://metadatahub.eu/data/geologic-timescale> ;
    skos:definition "Hanseatic League dominates Baltic trade; German merchants in Visby, Bergen, Stockholm; Lübeck law adopted."@en ;
    gts:rank "CulturalAge" ;
    skos:broader ts:medieval-period ;
    time:hasBeginning [ rdfs:label "1250 CE" ] ;
    time:hasEnd [ rdfs:label "1450 CE" ] ;
    dcterms:source <https://en.wikipedia.org/wiki/Geologic_time_scale> .

# ── 248/250: Kalmar Union (CulturalAge) ──
ts:kalmar-union a gts:GeochronologicAge ;
    rdfs:label "Kalmar Union"@en ;
    skos:inScheme <https://metadatahub.eu/data/geologic-timescale> ;
    skos:definition "Union of Denmark, Norway, and Sweden under one monarch; Queen Margrete I; dissolved by Gustav Vasa's rebellion."@en ;
    gts:rank "CulturalAge" ;
    skos:broader ts:late-medieval ;
    time:hasBeginning [ rdfs:label "1397 CE" ] ;
    time:hasEnd [ rdfs:label "1523 CE" ] ;
    dcterms:source <https://en.wikipedia.org/wiki/Geologic_time_scale> .

# ── 249/250: Eocene–Oligocene Extinction (Grande Coupure) (Age) ──
ts:eocene-oligocene-extinction a gts:GeochronologicAge ;
    rdfs:label "Eocene–Oligocene Extinction (Grande Coupure)"@en ;
    skos:inScheme <https://metadatahub.eu/data/geologic-timescale> ;
    skos:definition "Major faunal turnover in Europe; Asian mammals invade; dramatic cooling as Antarctic ice sheet forms."@en ;
    gts:rank "Age" ;
    skos:broader ts:priabonian ;
    time:hasBeginning [ time:inXSDgYear "33.9"^^xsd:decimal ; rdfs:label "33.9 Ma" ] ;
    time:hasEnd [ time:inXSDgYear "33.7"^^xsd:decimal ; rdfs:label "33.7 Ma" ] ;
    dcterms:source <https://en.wikipedia.org/wiki/Geologic_time_scale> .

# ── 250/250: Cambrian Explosion (Age) ──
ts:cambrian-explosion a gts:GeochronologicAge ;
    rdfs:label "Cambrian Explosion"@en ;
    skos:inScheme <https://metadatahub.eu/data/geologic-timescale> ;
    skos:definition "Most major animal phyla appear in fossil record within ~25 Myr; Burgess Shale, Chengjiang faunas; cause debated."@en ;
    gts:rank "Age" ;
    skos:broader ts:epoch2-cambrian ;
    time:hasBeginning [ time:inXSDgYear "538.8"^^xsd:decimal ; rdfs:label "538.8 Ma" ] ;
    time:hasEnd [ time:inXSDgYear "510"^^xsd:decimal ; rdfs:label "510 Ma" ] ;
    dcterms:source <https://en.wikipedia.org/wiki/Geologic_time_scale> .
