    time:hasEnd [ time:inXSDgYear "529"^^xsd:decimal ; rdfs:label "529 Ma" ] ;
    dcterms:source <https://en.wikipedia.org/wiki/Geologic_time_scale> .

# ── 31/250: Cambrian Stage 2 (Age) ──
ts:stage2-cambrian a gts:GeochronologicAge ;
    rdfs:label "Cambrian Stage 2"@en ;
    skos:inScheme <https://metadatahub.eu/data/geologic-timescale> ;
    skos:definition "Small shelly fauna diversify; archaeocyathids appear."@en ;
