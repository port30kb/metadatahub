# ═══════════════════════════════════════════════════════════════
# Geologic Time Scale — Linked Data for metadatahub.eu
# 514 data points: eons, eras, periods, epochs, ages,
# and archaeological/cultural periods bridging to human history.
#
# Source: Wikipedia, 'Geologic time scale'
#   https://en.wikipedia.org/wiki/Geologic_time_scale
# Additional sources:
#   https://en.wikipedia.org/wiki/Holocene
#   https://en.wikipedia.org/wiki/Pleistocene
#   https://en.wikipedia.org/wiki/Three-age_system
#   https://en.wikipedia.org/wiki/Scandinavian_prehistory
#   https://en.wikipedia.org/wiki/Viking_Age
# ICS International Chronostratigraphic Chart v2024/12
#   https://stratigraphy.org/ICSchart/ChronostratChart2024-12.pdf
#
# Total entries: 514
# ═══════════════════════════════════════════════════════════════

@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix gts:     <http://resource.geosciml.org/ontology/timescale/gts#> .
@prefix isc:     <http://resource.geosciml.org/classifier/ics/ischart/> .
@prefix ts:      <https://metadatahub.eu/data/geologic-timescale/> .

<https://metadatahub.eu/data/geologic-timescale> a skos:ConceptScheme ;
    dcterms:title "Geologic Time Scale"@en ;
    dcterms:description "514 entries covering the geologic time scale from Hadean eon (4600 Ma) to present, including Scandinavian, European, and South American cultural/historical periods."@en ;
    dcterms:source <https://en.wikipedia.org/wiki/Geologic_time_scale> ;
    dcterms:source <https://stratigraphy.org/ICSchart/ChronostratChart2024-12.pdf> ;
    dcterms:source <https://en.wikipedia.org/wiki/Holocene> ;
    dcterms:source <https://en.wikipedia.org/wiki/Pleistocene> ;
    dcterms:source <https://en.wikipedia.org/wiki/Three-age_system> ;
    dcterms:source <https://en.wikipedia.org/wiki/Scandinavian_prehistory> ;
    dcterms:source <https://en.wikipedia.org/wiki/Viking_Age> ;
    dcterms:source <https://en.wikipedia.org/wiki/History_of_Europe> ;
    dcterms:source <https://en.wikipedia.org/wiki/Nordic_Bronze_Age> ;
    dcterms:source <https://en.wikipedia.org/wiki/Iron_Age_Scandinavia> ;
    dcterms:source <https://en.wikipedia.org/wiki/History_of_Sweden> ;
    dcterms:creator "Port 30 KB" ;
    dcterms:license <https://creativecommons.org/licenses/by-sa/4.0/> ;
    dcterms:modified "2024-12-01"^^xsd:date .

# ── 1/514: Hadean (Eon) ──
ts:hadean a gts:GeochronologicEon ;
    rdfs:label "Hadean"@en ;
    skos:inScheme <https://metadatahub.eu/data/geologic-timescale> ;
    skos:definition "Earliest eon; Earth forms from accretion, heavy bombardment, formation of the Moon."@en ;
    gts:rank "Eon" ;
    time:hasBeginning [ time:inXSDgYear "4600"^^xsd:decimal ; rdfs:label "4600 Ma" ] ;
    time:hasEnd [ time:inXSDgYear "4000"^^xsd:decimal ; rdfs:label "4000 Ma" ] ;
    dcterms:source <https://en.wikipedia.org/wiki/Geologic_time_scale> .

# ── 2/514: Ginallian (informal) (Era) ──
ts:ginallian a gts:GeochronologicEra ;
    rdfs:label "Ginallian (informal)"@en ;
    skos:inScheme <https://metadatahub.eu/data/geologic-timescale> ;
    skos:definition "Accretion and differentiation of Earth; formation of core and mantle from planetesimals."@en ;
    gts:rank "Era" ;
    skos:broader ts:hadean ;
    time:hasBeginning [ time:inXSDgYear "4600"^^xsd:decimal ; rdfs:label "4600 Ma" ] ;
    time:hasEnd [ time:inXSDgYear "4510"^^xsd:decimal ; rdfs:label "4510 Ma" ] ;
    dcterms:source <https://en.wikipedia.org/wiki/Geologic_time_scale> .

# ── 3/514: Chaotian (informal) (Era) ──
ts:chaotian a gts:GeochronologicEra ;
    rdfs:label "Chaotian (informal)"@en ;
    skos:inScheme <https://metadatahub.eu/data/geologic-timescale> ;
    skos:definition "Moon-forming giant impact (Theia hypothesis); surface entirely molten magma ocean."@en ;
    gts:rank "Era" ;
    skos:broader ts:hadean ;
    time:hasBeginning [ time:inXSDgYear "4510"^^xsd:decimal ; rdfs:label "4510 Ma" ] ;
    time:hasEnd [ time:inXSDgYear "4404"^^xsd:decimal ; rdfs:label "4404 Ma" ] ;
    dcterms:source <https://en.wikipedia.org/wiki/Geologic_time_scale> .

# ── 4/514: Zirconian (informal) (Era) ──
ts:zirconian a gts:GeochronologicEra ;
    rdfs:label "Zirconian (informal)"@en ;
    skos:inScheme <https://metadatahub.eu/data/geologic-timescale> ;
    skos:definition "Oldest known mineral grains (Jack Hills zircons, ~4.4 Ga); first solid crust forms; Late Heavy Bombardment."@en ;
    gts:rank "Era" ;
    skos:broader ts:hadean ;
    time:hasBeginning [ time:inXSDgYear "4404"^^xsd:decimal ; rdfs:label "4404 Ma" ] ;
    time:hasEnd [ time:inXSDgYear "4030"^^xsd:decimal ; rdfs:label "4030 Ma" ] ;
    dcterms:source <https://en.wikipedia.org/wiki/Geologic_time_scale> .

# ── 5/514: Archean (Eon) ──
ts:archean a gts:GeochronologicEon ;
    rdfs:label "Archean"@en ;
    skos:inScheme <https://metadatahub.eu/data/geologic-timescale> ;
    skos:definition "First stable continents form; earliest evidence of life (stromatolites)."@en ;
    gts:rank "Eon" ;
    time:hasBeginning [ time:inXSDgYear "4000"^^xsd:decimal ; rdfs:label "4000 Ma" ] ;
    time:hasEnd [ time:inXSDgYear "2500"^^xsd:decimal ; rdfs:label "2500 Ma" ] ;
    dcterms:source <https://en.wikipedia.org/wiki/Geologic_time_scale> .

# ── 6/514: Proterozoic (Eon) ──
ts:proterozoic a gts:GeochronologicEon ;
    rdfs:label "Proterozoic"@en ;
    skos:inScheme <https://metadatahub.eu/data/geologic-timescale> ;
    skos:definition "Oxygen accumulates in atmosphere; first eukaryotes and multicellular life."@en ;
    gts:rank "Eon" ;
    time:hasBeginning [ time:inXSDgYear "2500"^^xsd:decimal ; rdfs:label "2500 Ma" ] ;
    time:hasEnd [ time:inXSDgYear "538.8"^^xsd:decimal ; rdfs:label "538.8 Ma" ] ;
    dcterms:source <https://en.wikipedia.org/wiki/Geologic_time_scale> .

# ── 7/514: Phanerozoic (Eon) ──
ts:phanerozoic a gts:GeochronologicEon ;
    rdfs:label "Phanerozoic"@en ;
    skos:inScheme <https://metadatahub.eu/data/geologic-timescale> ;
    skos:definition "Eon of visible life; all complex animal phyla appear and diversify."@en ;
    gts:rank "Eon" ;
    time:hasBeginning [ time:inXSDgYear "538.8"^^xsd:decimal ; rdfs:label "538.8 Ma" ] ;
    time:hasEnd [ rdfs:label "Present" ] ;
    dcterms:source <https://en.wikipedia.org/wiki/Geologic_time_scale> .

# ── 8/514: Eoarchean (Era) ──
ts:eoarchean a gts:GeochronologicEra ;
    rdfs:label "Eoarchean"@en ;
    skos:inScheme <https://metadatahub.eu/data/geologic-timescale> ;
    skos:definition "Oldest known rocks; possible earliest life."@en ;
    gts:rank "Era" ;
    skos:broader ts:archean ;
    time:hasBeginning [ time:inXSDgYear "4000"^^xsd:decimal ; rdfs:label "4000 Ma" ] ;
    time:hasEnd [ time:inXSDgYear "3600"^^xsd:decimal ; rdfs:label "3600 Ma" ] ;
    dcterms:source <https://en.wikipedia.org/wiki/Geologic_time_scale> .

# ── 9/514: Paleoarchean (Era) ──
ts:paleoarchean a gts:GeochronologicEra ;
    rdfs:label "Paleoarchean"@en ;
    skos:inScheme <https://metadatahub.eu/data/geologic-timescale> ;
    skos:definition "Earliest confirmed microbial life; oldest stromatolites."@en ;
    gts:rank "Era" ;
    skos:broader ts:archean ;
    time:hasBeginning [ time:inXSDgYear "3600"^^xsd:decimal ; rdfs:label "3600 Ma" ] ;
    time:hasEnd [ time:inXSDgYear "3200"^^xsd:decimal ; rdfs:label "3200 Ma" ] ;
    dcterms:source <https://en.wikipedia.org/wiki/Geologic_time_scale> .

# ── 10/514: Mesoarchean (Era) ──
ts:mesoarchean a gts:GeochronologicEra ;
    rdfs:label "Mesoarchean"@en ;
    skos:inScheme <https://metadatahub.eu/data/geologic-timescale> ;
    skos:definition "First large-scale stromatolite reefs; earliest photosynthesis evidence."@en ;
    gts:rank "Era" ;
    skos:broader ts:archean ;
    time:hasBeginning [ time:inXSDgYear "3200"^^xsd:decimal ; rdfs:label "3200 Ma" ] ;
    time:hasEnd [ time:inXSDgYear "2800"^^xsd:decimal ; rdfs:label "2800 Ma" ] ;
    dcterms:source <https://en.wikipedia.org/wiki/Geologic_time_scale> .

# ── 11/514: Neoarchean (Era) ──
ts:neoarchean a gts:GeochronologicEra ;
    rdfs:label "Neoarchean"@en ;
    skos:inScheme <https://metadatahub.eu/data/geologic-timescale> ;
    skos:definition "Oxygen-producing cyanobacteria proliferate; banded iron formations peak."@en ;
    gts:rank "Era" ;
    skos:broader ts:archean ;
    time:hasBeginning [ time:inXSDgYear "2800"^^xsd:decimal ; rdfs:label "2800 Ma" ] ;
    time:hasEnd [ time:inXSDgYear "2500"^^xsd:decimal ; rdfs:label "2500 Ma" ] ;
    dcterms:source <https://en.wikipedia.org/wiki/Geologic_time_scale> .

# ── 12/514: Paleoproterozoic (Era) ──
ts:paleoproterozoic a gts:GeochronologicEra ;
    rdfs:label "Paleoproterozoic"@en ;
    skos:inScheme <https://metadatahub.eu/data/geologic-timescale> ;
    skos:definition "Great Oxidation Event; first supercontinent (Nuna/Columbia)."@en ;
    gts:rank "Era" ;
    skos:broader ts:proterozoic ;
    time:hasBeginning [ time:inXSDgYear "2500"^^xsd:decimal ; rdfs:label "2500 Ma" ] ;
    time:hasEnd [ time:inXSDgYear "1600"^^xsd:decimal ; rdfs:label "1600 Ma" ] ;
    dcterms:source <https://en.wikipedia.org/wiki/Geologic_time_scale> .

# ── 13/514: Siderian (Period) ──
ts:siderian a gts:GeochronologicPeriod ;
    rdfs:label "Siderian"@en ;
    skos:inScheme <https://metadatahub.eu/data/geologic-timescale> ;
    skos:definition "Banded iron formations dominate; oxygen levels still rising."@en ;
    gts:rank "Period" ;
    skos:broader ts:paleoproterozoic ;
    time:hasBeginning [ time:inXSDgYear "2500"^^xsd:decimal ; rdfs:label "2500 Ma" ] ;
    time:hasEnd [ time:inXSDgYear "2300"^^xsd:decimal ; rdfs:label "2300 Ma" ] ;
    dcterms:source <https://en.wikipedia.org/wiki/Geologic_time_scale> .

# ── 14/514: Rhyacian (Period) ──
ts:rhyacian a gts:GeochronologicPeriod ;
    rdfs:label "Rhyacian"@en ;
    skos:inScheme <https://metadatahub.eu/data/geologic-timescale> ;
    skos:definition "Huronian glaciation; first global ice age."@en ;
    gts:rank "Period" ;
    skos:broader ts:paleoproterozoic ;
    time:hasBeginning [ time:inXSDgYear "2300"^^xsd:decimal ; rdfs:label "2300 Ma" ] ;
    time:hasEnd [ time:inXSDgYear "2050"^^xsd:decimal ; rdfs:label "2050 Ma" ] ;
    dcterms:source <https://en.wikipedia.org/wiki/Geologic_time_scale> .

# ── 15/514: Orosirian (Period) ──
ts:orosirian a gts:GeochronologicPeriod ;
    rdfs:label "Orosirian"@en ;
    skos:inScheme <https://metadatahub.eu/data/geologic-timescale> ;
    skos:definition "Major mountain-building events; Vredefort and Sudbury impacts."@en ;
    gts:rank "Period" ;
    skos:broader ts:paleoproterozoic ;
    time:hasBeginning [ time:inXSDgYear "2050"^^xsd:decimal ; rdfs:label "2050 Ma" ] ;
    time:hasEnd [ time:inXSDgYear "1800"^^xsd:decimal ; rdfs:label "1800 Ma" ] ;
    dcterms:source <https://en.wikipedia.org/wiki/Geologic_time_scale> .

# ── 16/514: Statherian (Period) ──
ts:statherian a gts:GeochronologicPeriod ;
    rdfs:label "Statherian"@en ;
    skos:inScheme <https://metadatahub.eu/data/geologic-timescale> ;
    skos:definition "First complex single-celled organisms with nuclei."@en ;
    gts:rank "Period" ;
    skos:broader ts:paleoproterozoic ;
    time:hasBeginning [ time:inXSDgYear "1800"^^xsd:decimal ; rdfs:label "1800 Ma" ] ;
    time:hasEnd [ time:inXSDgYear "1600"^^xsd:decimal ; rdfs:label "1600 Ma" ] ;
    dcterms:source <https://en.wikipedia.org/wiki/Geologic_time_scale> .

# ── 17/514: Mesoproterozoic (Era) ──
ts:mesoproterozoic a gts:GeochronologicEra ;
    rdfs:label "Mesoproterozoic"@en ;
    skos:inScheme <https://metadatahub.eu/data/geologic-timescale> ;
    skos:definition "Supercontinent Rodinia assembles; first sexual reproduction evidence."@en ;
    gts:rank "Era" ;
    skos:broader ts:proterozoic ;
    time:hasBeginning [ time:inXSDgYear "1600"^^xsd:decimal ; rdfs:label "1600 Ma" ] ;
    time:hasEnd [ time:inXSDgYear "1000"^^xsd:decimal ; rdfs:label "1000 Ma" ] ;
    dcterms:source <https://en.wikipedia.org/wiki/Geologic_time_scale> .

# ── 18/514: Calymmian (Period) ──
ts:calymmian a gts:GeochronologicPeriod ;
    rdfs:label "Calymmian"@en ;
    skos:inScheme <https://metadatahub.eu/data/geologic-timescale> ;
    skos:definition "Platform covers expand; stable continental interiors."@en ;
    gts:rank "Period" ;
    skos:broader ts:mesoproterozoic ;
    time:hasBeginning [ time:inXSDgYear "1600"^^xsd:decimal ; rdfs:label "1600 Ma" ] ;
    time:hasEnd [ time:inXSDgYear "1400"^^xsd:decimal ; rdfs:label "1400 Ma" ] ;
    dcterms:source <https://en.wikipedia.org/wiki/Geologic_time_scale> .

# ── 19/514: Ectasian (Period) ──
ts:ectasian a gts:GeochronologicPeriod ;
    rdfs:label "Ectasian"@en ;
    skos:inScheme <https://metadatahub.eu/data/geologic-timescale> ;
    skos:definition "Continued platform expansion; green algae diversify."@en ;
    gts:rank "Period" ;
    skos:broader ts:mesoproterozoic ;
    time:hasBeginning [ time:inXSDgYear "1400"^^xsd:decimal ; rdfs:label "1400 Ma" ] ;
    time:hasEnd [ time:inXSDgYear "1200"^^xsd:decimal ; rdfs:label "1200 Ma" ] ;
    dcterms:source <https://en.wikipedia.org/wiki/Geologic_time_scale> .

# ── 20/514: Stenian (Period) ──
ts:stenian a gts:GeochronologicPeriod ;
    rdfs:label "Stenian"@en ;
    skos:inScheme <https://metadatahub.eu/data/geologic-timescale> ;
    skos:definition "Grenville orogeny; supercontinent Rodinia forms."@en ;
    gts:rank "Period" ;
    skos:broader ts:mesoproterozoic ;
    time:hasBeginning [ time:inXSDgYear "1200"^^xsd:decimal ; rdfs:label "1200 Ma" ] ;
    time:hasEnd [ time:inXSDgYear "1000"^^xsd:decimal ; rdfs:label "1000 Ma" ] ;
    dcterms:source <https://en.wikipedia.org/wiki/Geologic_time_scale> .

# ── 21/514: Neoproterozoic (Era) ──
ts:neoproterozoic a gts:GeochronologicEra ;
    rdfs:label "Neoproterozoic"@en ;
    skos:inScheme <https://metadatahub.eu/data/geologic-timescale> ;
    skos:definition "Snowball Earth glaciations; first animals appear (Ediacaran biota)."@en ;
    gts:rank "Era" ;
    skos:broader ts:proterozoic ;
    time:hasBeginning [ time:inXSDgYear "1000"^^xsd:decimal ; rdfs:label "1000 Ma" ] ;
    time:hasEnd [ time:inXSDgYear "538.8"^^xsd:decimal ; rdfs:label "538.8 Ma" ] ;
    dcterms:source <https://en.wikipedia.org/wiki/Geologic_time_scale> .

# ── 22/514: Tonian (Period) ──
ts:tonian a gts:GeochronologicPeriod ;
    rdfs:label "Tonian"@en ;
    skos:inScheme <https://metadatahub.eu/data/geologic-timescale> ;
    skos:definition "Rodinia begins to break apart; first multicellular organisms."@en ;
    gts:rank "Period" ;
    skos:broader ts:neoproterozoic ;
    time:hasBeginning [ time:inXSDgYear "1000"^^xsd:decimal ; rdfs:label "1000 Ma" ] ;
    time:hasEnd [ time:inXSDgYear "720"^^xsd:decimal ; rdfs:label "720 Ma" ] ;
    dcterms:source <https://en.wikipedia.org/wiki/Geologic_time_scale> .

# ── 23/514: Cryogenian (Period) ──
ts:cryogenian a gts:GeochronologicPeriod ;
    rdfs:label "Cryogenian"@en ;
    skos:inScheme <https://metadatahub.eu/data/geologic-timescale> ;
    skos:definition "Snowball Earth glaciations: Sturtian and Marinoan; life survives in refugia."@en ;
    gts:rank "Period" ;
    skos:broader ts:neoproterozoic ;
    time:hasBeginning [ time:inXSDgYear "720"^^xsd:decimal ; rdfs:label "720 Ma" ] ;
    time:hasEnd [ time:inXSDgYear "635"^^xsd:decimal ; rdfs:label "635 Ma" ] ;
    dcterms:source <https://en.wikipedia.org/wiki/Geologic_time_scale> .

# ── 24/514: Sturtian Glaciation (Age) ──
ts:sturtian a gts:GeochronologicAge ;
    rdfs:label "Sturtian Glaciation"@en ;
    skos:inScheme <https://metadatahub.eu/data/geologic-timescale> ;
    skos:definition "First and longer Snowball Earth event; global ice cover for ~57 million years."@en ;
    gts:rank "Age" ;
    skos:broader ts:cryogenian ;
    time:hasBeginning [ time:inXSDgYear "717"^^xsd:decimal ; rdfs:label "717 Ma" ] ;
    time:hasEnd [ time:inXSDgYear "660"^^xsd:decimal ; rdfs:label "660 Ma" ] ;
    dcterms:source <https://en.wikipedia.org/wiki/Geologic_time_scale> .

# ── 25/514: Marinoan Glaciation (Age) ──
ts:marinoan a gts:GeochronologicAge ;
    rdfs:label "Marinoan Glaciation"@en ;
    skos:inScheme <https://metadatahub.eu/data/geologic-timescale> ;
    skos:definition "Second Snowball Earth; cap carbonates deposited after deglaciation."@en ;
    gts:rank "Age" ;
    skos:broader ts:cryogenian ;
    time:hasBeginning [ time:inXSDgYear "650"^^xsd:decimal ; rdfs:label "650 Ma" ] ;
    time:hasEnd [ time:inXSDgYear "635"^^xsd:decimal ; rdfs:label "635 Ma" ] ;
    dcterms:source <https://en.wikipedia.org/wiki/Geologic_time_scale> .

# ── 26/514: Ediacaran (Period) ──
ts:ediacaran a gts:GeochronologicPeriod ;
    rdfs:label "Ediacaran"@en ;
    skos:inScheme <https://metadatahub.eu/data/geologic-timescale> ;
    skos:definition "Ediacaran biota: first large complex organisms; soft-bodied fauna."@en ;
    gts:rank "Period" ;
    skos:broader ts:neoproterozoic ;
    time:hasBeginning [ time:inXSDgYear "635"^^xsd:decimal ; rdfs:label "635 Ma" ] ;
    time:hasEnd [ time:inXSDgYear "538.8"^^xsd:decimal ; rdfs:label "538.8 Ma" ] ;
    dcterms:source <https://en.wikipedia.org/wiki/Geologic_time_scale> .

# ── 27/514: Paleozoic (Era) ──
ts:paleozoic a gts:GeochronologicEra ;
    rdfs:label "Paleozoic"@en ;
    skos:inScheme <https://metadatahub.eu/data/geologic-timescale> ;
    skos:definition "Era of ancient life; Cambrian explosion, first fish, amphibians, reptiles, forests."@en ;
    gts:rank "Era" ;
    skos:broader ts:phanerozoic ;
    time:hasBeginning [ time:inXSDgYear "538.8"^^xsd:decimal ; rdfs:label "538.8 Ma" ] ;
    time:hasEnd [ time:inXSDgYear "251.9"^^xsd:decimal ; rdfs:label "251.9 Ma" ] ;
    dcterms:source <https://en.wikipedia.org/wiki/Geologic_time_scale> .

# ── 28/514: Cambrian (Period) ──
ts:cambrian a gts:GeochronologicPeriod ;
    rdfs:label "Cambrian"@en ;
    skos:inScheme <https://metadatahub.eu/data/geologic-timescale> ;
    skos:definition "Cambrian explosion: most major animal phyla appear rapidly in the fossil record."@en ;
    gts:rank "Period" ;
    skos:broader ts:paleozoic ;
    time:hasBeginning [ time:inXSDgYear "538.8"^^xsd:decimal ; rdfs:label "538.8 Ma" ] ;
