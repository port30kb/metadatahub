    },
    {
      "@id": "https://metadatahub.eu/data/geologic-timescale/late-heavy-bombardment",
      "@type": "gts:GeochronologicAge",
      "rdfs:label": [
        {
          "@value": "Late Heavy Bombardment (LHB)",
          "@language": "en"
        },
        {
          "@value": "Sena tunga bombardemanget",
          "@language": "sv"
        }
      ],
      "skos:prefLabel": {
        "@value": "Late Heavy Bombardment (LHB)",
        "@language": "en"
      },
      "skos:definition": {
        "@value": "Proposed period of intense asteroid and comet impacts on inner Solar System; evidence from lunar craters and Apollo samples; shaped early Earth crust; timing and intensity debated (Nice model).",
        "@language": "en"
      },
      "gts:rank": "Age",
      "skos:broader": {
        "@id": "https://metadatahub.eu/data/geologic-timescale/hadean"
      },
      "time:hasBeginning": "4100 Ma",
      "time:hasEnd": "3800 Ma",
      "dcterms:source": "https://en.wikipedia.org/wiki/Geologic_time_scale"
    },
