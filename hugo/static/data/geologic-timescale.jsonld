      "rdfs:label": {
        "@value": "Neoarchean",
        "@language": "en"
      },
      "skos:definition": {
        "@value": "Oxygen-producing cyanobacteria proliferate; banded iron formations peak.",
        "@language": "en"
      },
      "gts:rank": "Era",
      "skos:broader": {
        "@id": "https://metadatahub.eu/data/geologic-timescale/archean"
      },
      "time:hasBeginning": "2800 Ma",
      "time:hasEnd": "2500 Ma",
      "dcterms:source": "https://en.wikipedia.org/wiki/Geologic_time_scale"
    },
    {
      "@id": "https://metadatahub.eu/data/geologic-timescale/paleoproterozoic",
