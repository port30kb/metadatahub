    {
      "@id": "https://metadatahub.eu/data/geologic-timescale/hadean",
      "@type": "gts:GeochronologicEon",
      "rdfs:label": [
        {
          "@value": "Hadean",
          "@language": "en"
        },
        {
          "@value": "Ἅιδης",
          "@language": "grc"
        },
        {
          "@value": "Hadeikum",
          "@language": "sv"
        }
      ],
      "skos:prefLabel": {
        "@value": "Hadean",
        "@language": "en"
      },
      "skos:definition": {
        "@value": "Earliest eon; Earth forms from accretion, heavy bombardment, formation of the Moon.",
        "@language": "en"
      },
      "gts:rank": "Eon",
      "time:hasBeginning": "4567 Ma",
      "time:hasEnd": "4031 Ma",
      "dcterms:source": "https://en.wikipedia.org/wiki/Geologic_time_scale"
    },
    {
      "@id": "https://metadatahub.eu/data/geologic-timescale/chaotian",
      "@type": "gts:GeochronologicEra",
      "rdfs:label": [
        {
          "@value": "Chaotian (informal)",
          "@language": "en"
        },
        {
          "@value": "Χάος",
          "@language": "grc"
        },
        {
          "@value": "Chaotium (informell)",
          "@language": "sv"
        }
      ],
      "skos:prefLabel": {
        "@value": "Chaotian (informal)",
        "@language": "en"
      },
      "skos:definition": {
        "@value": "Accretion and differentiation of Earth; Moon-forming giant impact (Theia hypothesis, ~4510 Ma); surface entirely molten magma ocean.",
        "@language": "en"
      },
      "gts:rank": "Era",
      "skos:broader": {
        "@id": "https://metadatahub.eu/data/geologic-timescale/hadean"
      },
      "time:hasBeginning": "4567 Ma",
      "time:hasEnd": "4404 Ma",
      "dcterms:source": "https://en.wikipedia.org/wiki/Geologic_time_scale"
    },
    {
      "@id": "https://metadatahub.eu/data/geologic-timescale/zirconian",
      "@type": "gts:GeochronologicEra",
      "rdfs:label": [
        {
          "@value": "Zirconian (informal)",
