  "@graph": [
    {
      "@id": "https://metadatahub.eu/data/geologic-timescale/hadean",
      "@type": "gts:GeochronologicEon",
      "rdfs:label": {
        "@value": "Hadean",
        "@language": "en"
      },
      "skos:definition": {
        "@value": "Earliest eon; Earth forms from accretion, heavy bombardment, formation of the Moon.",
        "@language": "en"
      },
      "gts:rank": "Eon",
      "time:hasBeginning": "4600 Ma",
      "time:hasEnd": "4000 Ma",
      "dcterms:source": "https://en.wikipedia.org/wiki/Geologic_time_scale"
    },
    {
      "@id": "https://metadatahub.eu/data/geologic-timescale/ginallian",
      "@type": "gts:GeochronologicEra",
      "rdfs:label": {
        "@value": "Ginallian (informal)",
        "@language": "en"
      },
      "skos:definition": {
        "@value": "Accretion and differentiation of Earth; formation of core and mantle from planetesimals.",
        "@language": "en"
      },
      "gts:rank": "Era",
      "skos:broader": {
        "@id": "https://metadatahub.eu/data/geologic-timescale/hadean"
      },
      "time:hasBeginning": "4600 Ma",
      "time:hasEnd": "4510 Ma",
      "dcterms:source": "https://en.wikipedia.org/wiki/Geologic_time_scale"
    },
    {
      "@id": "https://metadatahub.eu/data/geologic-timescale/chaotian",
      "@type": "gts:GeochronologicEra",
      "rdfs:label": {
        "@value": "Chaotian (informal)",
        "@language": "en"
      },
      "skos:definition": {
        "@value": "Moon-forming giant impact (Theia hypothesis); surface entirely molten magma ocean.",
        "@language": "en"
      },
      "gts:rank": "Era",
      "skos:broader": {
        "@id": "https://metadatahub.eu/data/geologic-timescale/hadean"
      },
      "time:hasBeginning": "4510 Ma",
      "time:hasEnd": "4404 Ma",
      "dcterms:source": "https://en.wikipedia.org/wiki/Geologic_time_scale"
    },
    {
      "@id": "https://metadatahub.eu/data/geologic-timescale/zirconian",
      "@type": "gts:GeochronologicEra",
      "rdfs:label": {
        "@value": "Zirconian (informal)",
        "@language": "en"
      },
      "skos:definition": {
        "@value": "Oldest known mineral grains (Jack Hills zircons, ~4.4 Ga); first solid crust forms; Late Heavy Bombardment.",
        "@language": "en"
      },
      "gts:rank": "Era",
      "skos:broader": {
        "@id": "https://metadatahub.eu/data/geologic-timescale/hadean"
      },
      "time:hasBeginning": "4404 Ma",
      "time:hasEnd": "4030 Ma",
      "dcterms:source": "https://en.wikipedia.org/wiki/Geologic_time_scale"
    },
    {
      "@id": "https://metadatahub.eu/data/geologic-timescale/archean",
      "@type": "gts:GeochronologicEon",
      "rdfs:label": {
        "@value": "Archean",
        "@language": "en"
      },
      "skos:definition": {
        "@value": "First stable continents form; earliest evidence of life (stromatolites).",
        "@language": "en"
      },
      "gts:rank": "Eon",
      "time:hasBeginning": "4000 Ma",
      "time:hasEnd": "2500 Ma",
      "dcterms:source": "https://en.wikipedia.org/wiki/Geologic_time_scale"
    },
    {
      "@id": "https://metadatahub.eu/data/geologic-timescale/proterozoic",
      "@type": "gts:GeochronologicEon",
      "rdfs:label": {
        "@value": "Proterozoic",
        "@language": "en"
      },
      "skos:definition": {
        "@value": "Oxygen accumulates in atmosphere; first eukaryotes and multicellular life.",
        "@language": "en"
      },
      "gts:rank": "Eon",
      "time:hasBeginning": "2500 Ma",
      "time:hasEnd": "538.8 Ma",
      "dcterms:source": "https://en.wikipedia.org/wiki/Geologic_time_scale"
    },
    {
      "@id": "https://metadatahub.eu/data/geologic-timescale/phanerozoic",
      "@type": "gts:GeochronologicEon",
      "rdfs:label": {
        "@value": "Phanerozoic",
        "@language": "en"
      },
      "skos:definition": {
        "@value": "Eon of visible life; all complex animal phyla appear and diversify.",
        "@language": "en"
      },
      "gts:rank": "Eon",
      "time:hasBeginning": "538.8 Ma",
      "time:hasEnd": "Present",
      "dcterms:source": "https://en.wikipedia.org/wiki/Geologic_time_scale"
    },
    {
      "@id": "https://metadatahub.eu/data/geologic-timescale/eoarchean",
