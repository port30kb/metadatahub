    },
    {
      "@id": "https://metadatahub.eu/data/geologic-timescale/mesoarchean",
      "@type": "gts:GeochronologicEra",
      "rdfs:label": {
        "@value": "Mesoarchean",
        "@language": "en"
      },
      "skos:definition": {
        "@value": "First large-scale stromatolite reefs; earliest photosynthesis evidence.",
        "@language": "en"
      },
      "gts:rank": "Era",
      "skos:broader": {
        "@id": "https://metadatahub.eu/data/geologic-timescale/archean"
      },
      "time:hasBeginning": "3200 Ma",
      "time:hasEnd": "2800 Ma",
