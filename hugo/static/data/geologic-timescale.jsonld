        "@value": "Paleoarchean",
        "@language": "en"
      },
      "skos:definition": {
        "@value": "Earliest confirmed microbial life; oldest stromatolites.",
        "@language": "en"
      },
      "gts:rank": "Era",
      "skos:broader": {
        "@id": "https://metadatahub.eu/data/geologic-timescale/archean"
      },
      "time:hasBeginning": "3600 Ma",
      "time:hasEnd": "3200 Ma",
