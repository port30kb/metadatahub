      "rdfs:label": {
        "@value": "Eoarchean",
        "@language": "en"
      },
      "skos:definition": {
        "@value": "Oldest known rocks; possible earliest life.",
        "@language": "en"
      },
      "gts:rank": "Era",
      "skos:broader": {
        "@id": "https://metadatahub.eu/data/geologic-timescale/archean"
      },
      "time:hasBeginning": "4000 Ma",
      "time:hasEnd": "3600 Ma",
      "dcterms:source": "https://en.wikipedia.org/wiki/Geologic_time_scale"
    },
    {
      "@id": "https://metadatahub.eu/data/geologic-timescale/paleoarchean",
