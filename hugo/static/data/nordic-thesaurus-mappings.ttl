# ═══════════════════════════════════════════════════════════════
# Nordic Thesaurus Mappings — Linked Data for metadatahub.eu
# 99 SKOS mapping assertions between Nordic museum systems
# and international standards (Getty AAT).
#
# Systems:
#   ksamsok: K-samsök (Swedish Cultural Heritage)
#   digitaltmuseum: DigitaltMuseum (Norway/Sweden)
#   finna: Finna/YSO (Finland)
#   dkmuseum: Danish National Museum
#   aat: Getty Art & Architecture Thesaurus
#
# Total assertions: 99
# ═══════════════════════════════════════════════════════════════

@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix void:    <http://rdfs.org/ns/void#> .
@prefix map:     <https://metadatahub.eu/data/nordic-thesaurus-mappings/> .

<https://metadatahub.eu/data/nordic-thesaurus-mappings> a void:Linkset , skos:ConceptScheme ;
    dcterms:title "Nordic Thesaurus Mappings"@en ;
    dcterms:description "99 SKOS mapping assertions between Nordic museum classification systems (K-samsök, DigitaltMuseum, Finna, Danish museums) and Getty AAT."@en ;
    dcterms:creator "Port 30 KB" ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> ;
    dcterms:modified "2025-01-15"^^xsd:date ;
    void:triples "99"^^xsd:integer .

# ── 1/99: Painting (K-samsök → AAT) ──
