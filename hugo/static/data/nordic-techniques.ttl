<https://metadatahub.eu/data/nordic-techniques> a skos:ConceptScheme ;
    dcterms:title "Nordic Techniques Vocabulary"@en ;
    dcterms:title "Nordisk teknikvokabulär"@sv ;
    dcterms:description "153 entries covering techniques used in Nordic museum cataloguing — metalworking, textiles, woodworking, ceramics, stone, painting, printmaking, glass, leather, and Sami/Nordic-specific crafts."@en ;
